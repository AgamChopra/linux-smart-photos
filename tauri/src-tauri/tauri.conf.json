{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Smart Photos",
  "version": "0.1.0",
  "identifier": "app.linux-smart-photos.desktop",
  "build": {
    "frontendDist": "../renderer"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Smart Photos",
        "width": 1440,
        "height": 940,
        "minWidth": 1040,
        "minHeight": 720,
        "center": true,
        "resizable": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:*; img-src 'self' http://127.0.0.1:* data: blob:; media-src 'self' http://127.0.0.1:* data: blob:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png"
    ]
  }
}
