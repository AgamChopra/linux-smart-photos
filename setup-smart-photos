#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
VENV_DIR="$ROOT_DIR/.venv"
STAMP_FILE="$VENV_DIR/.smart-photos-setup.stamp"
ICON_SOURCE="$ROOT_DIR/assets/smart-photos.svg"
ICON_DEST_DIR="$HOME/.local/share/icons/hicolor/scalable/apps"
ICON_DEST="$ICON_DEST_DIR/smart-photos.svg"
DESKTOP_DIR="$HOME/.local/share/applications"
DESKTOP_FILE="$DESKTOP_DIR/smart-photos.desktop"
BIN_DIR="$HOME/.local/bin"
BIN_LINK="$BIN_DIR/smart-photos"
LAUNCHER_PATH="$ROOT_DIR/smart-photos"

force_setup="0"
check_only="0"

print_usage() {
  cat <<'EOF'
Usage: ./setup-smart-photos [--force] [--check] [--help]

  --force   Rebuild the virtual environment dependencies and refresh desktop integration
  --check   Exit 0 if setup is current, 10 if setup is needed
EOF
}

while (($#)); do
  case "$1" in
    --force)
      force_setup="1"
      shift
      ;;
    --check)
      check_only="1"
      shift
      ;;
    --help|-h)
      print_usage
      exit 0
      ;;
    *)
      echo "Unknown option: $1" >&2
      print_usage >&2
      exit 2
      ;;
  esac
done

if ! command -v python3 >/dev/null 2>&1; then
  echo "python3 is required to set up Smart Photos." >&2
  exit 1
fi

manifest_hash="$(python3 - "$ROOT_DIR" <<'PY'
from __future__ import annotations

import hashlib
from pathlib import Path
import sys

root = Path(sys.argv[1])
tracked = [
    root / "pyproject.toml",
    root / "setup-smart-photos",
    root / "smart-photos",
    root / "assets" / "smart-photos.svg",
]
digest = hashlib.sha256()
for path in tracked:
    digest.update(path.name.encode("utf-8"))
    if path.exists():
        digest.update(path.read_bytes())
print(digest.hexdigest())
PY
)"

setup_current="0"
if [[ -x "$VENV_DIR/bin/python" && -f "$STAMP_FILE" ]]; then
  if [[ "$(cat "$STAMP_FILE")" == "$manifest_hash" ]]; then
    setup_current="1"
  fi
fi

if [[ "$check_only" == "1" ]]; then
  if [[ "$force_setup" == "1" || "$setup_current" != "1" ]]; then
    exit 10
  fi
  exit 0
fi

if [[ "$force_setup" != "1" && "$setup_current" == "1" ]]; then
  echo "Smart Photos setup is already up to date."
  exit 0
fi

echo "Setting up Smart Photos in $ROOT_DIR"
python3 -m venv "$VENV_DIR"

echo "Installing Python dependencies"
"$VENV_DIR/bin/python" -m pip install --upgrade pip "setuptools<82" wheel
(
  cd "$ROOT_DIR"
  "$VENV_DIR/bin/pip" install -e ".[ai]"
)

echo "Initializing local configuration"
"$VENV_DIR/bin/python" -m linux_smart_photos.bootstrap --skip-models

echo "Installing desktop integration"
mkdir -p "$ICON_DEST_DIR" "$DESKTOP_DIR" "$BIN_DIR"
install -m 0644 "$ICON_SOURCE" "$ICON_DEST"
ln -snf "$LAUNCHER_PATH" "$BIN_LINK"

cat > "$DESKTOP_FILE" <<EOF
[Desktop Entry]
Version=1.0
Type=Application
Name=Smart Photos
Comment=Browse, search, and organize your local photo library
TryExec=$BIN_LINK
Exec=$BIN_LINK --gui
Icon=smart-photos
Terminal=false
Categories=Graphics;Photography;
StartupNotify=true
StartupWMClass=Smart Photos
EOF

if command -v update-desktop-database >/dev/null 2>&1; then
  update-desktop-database "$DESKTOP_DIR" >/dev/null 2>&1 || true
fi

printf '%s\n' "$manifest_hash" > "$STAMP_FILE"
echo "Smart Photos is ready."
