#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SETUP_SCRIPT="$ROOT_DIR/setup-smart-photos"
VENV_DIR="$ROOT_DIR/.venv"
TAURI_DIR="$ROOT_DIR/tauri"
TAURI_BINARY="$TAURI_DIR/src-tauri/target/release/smart-photos-tauri"
ELECTRON_DIR="$ROOT_DIR/electron"
ELECTRON_BINARY="$ELECTRON_DIR/node_modules/.bin/electron"

mode="tauri"
skip_setup="0"
force_setup="0"
setup_only="0"
passthrough=()

print_usage() {
  cat <<'EOF'
Usage: ./smart-photos [--gui] [--cli] [--setup] [--setup-only] [--help] [-- ...]

Modes:
  --gui          Launch the primary Tauri app (default)
  --tauri        Launch the primary Tauri app
  --qt           Launch the Qt diagnostics/fallback UI
  --electron     Launch the deprecated Electron UI if installed
  --cli          Launch the command-line interface

Setup:
  --setup        Force the bootstrap script to run before launching
  --setup-only   Run bootstrap and exit

Examples:
  ./smart-photos
  ./smart-photos --cli status
  ./smart-photos --cli search cat --limit 10
  ./smart-photos --qt
  ./smart-photos --setup-only
EOF
}

launch_qt() {
  if [[ -n "${QT_LOGGING_RULES:-}" ]]; then
    export QT_LOGGING_RULES="${QT_LOGGING_RULES};qt.qpa.services.warning=false"
  else
    export QT_LOGGING_RULES="qt.qpa.services.warning=false"
  fi
  exec "$VENV_DIR/bin/smart-photos-gui" "${passthrough[@]}"
}

spawn_setup_terminal() {
  local launcher_cmd
  printf -v launcher_cmd '%q --force && %q --no-setup --gui' "$SETUP_SCRIPT" "$ROOT_DIR/smart-photos"

  if command -v x-terminal-emulator >/dev/null 2>&1; then
    exec x-terminal-emulator -e bash -lc "$launcher_cmd"
  fi
  if command -v gnome-terminal >/dev/null 2>&1; then
    exec gnome-terminal -- bash -lc "$launcher_cmd"
  fi
  if command -v konsole >/dev/null 2>&1; then
    exec konsole -e bash -lc "$launcher_cmd"
  fi
  if command -v xfce4-terminal >/dev/null 2>&1; then
    exec xfce4-terminal --command="bash -lc \"$launcher_cmd\""
  fi
  if command -v kitty >/dev/null 2>&1; then
    exec kitty bash -lc "$launcher_cmd"
  fi
  if command -v alacritty >/dev/null 2>&1; then
    exec alacritty -e bash -lc "$launcher_cmd"
  fi
  if command -v xterm >/dev/null 2>&1; then
    exec xterm -e bash -lc "$launcher_cmd"
  fi
  return 1
}

sanitize_electron_env() {
  unset GTK_PATH
  unset GTK_MODULES
  unset GTK_EXE_PREFIX
  unset GTK_DATA_PREFIX
  unset GTK2_RC_FILES
  unset GTK_RC_FILES
  unset GTK_THEME
  unset GTK_IM_MODULE
  unset GDK_BACKEND
  unset GDK_PIXBUF_MODULEDIR
  unset GDK_PIXBUF_MODULE_FILE
  unset GIO_MODULE_DIR
  unset GI_TYPELIB_PATH
  unset LD_PRELOAD
  unset QT_PLUGIN_PATH
}

while (($#)); do
  case "$1" in
    --gui|gui|--tauri|tauri)
      mode="tauri"
      shift
      ;;
    --electron|electron)
      mode="electron"
      shift
      ;;
    --qt|qt)
      mode="qt"
      shift
      ;;
    --cli|cli)
      mode="cli"
      shift
      ;;
    --setup|--force)
      force_setup="1"
      shift
      ;;
    --setup-only)
      force_setup="1"
      setup_only="1"
      shift
      ;;
    --no-setup)
      skip_setup="1"
      shift
      ;;
    --help|-h)
      print_usage
      exit 0
      ;;
    --)
      shift
      passthrough+=("$@")
      break
      ;;
    *)
      passthrough+=("$1")
      shift
      ;;
  esac
done

if [[ "$skip_setup" != "1" ]]; then
  set +e
  "$SETUP_SCRIPT" --check >/dev/null 2>&1
  setup_status=$?
  set -e

  if [[ "$setup_status" -eq 10 && ! -t 1 && "$mode" != "cli" ]]; then
    if spawn_setup_terminal; then
      exit 0
    fi
  fi

  if [[ "$force_setup" == "1" ]]; then
    "$SETUP_SCRIPT" --force
  else
    "$SETUP_SCRIPT"
  fi
fi

if [[ "$setup_only" == "1" ]]; then
  exit 0
fi

if [[ ! -x "$VENV_DIR/bin/python" ]]; then
  echo "The Smart Photos virtual environment is missing. Run ./setup-smart-photos first." >&2
  exit 1
fi

if [[ "$mode" == "cli" ]]; then
  if [[ ${#passthrough[@]} -eq 0 ]]; then
    passthrough=("status")
  fi
  exec "$VENV_DIR/bin/smart-photos-cli" "${passthrough[@]}"
fi

if [[ "$mode" == "qt" ]]; then
  launch_qt
fi

if [[ "$mode" == "tauri" ]]; then
  if [[ ! -x "$TAURI_BINARY" ]]; then
    echo "Tauri UI is not built. Falling back to the Qt diagnostics interface." >&2
    launch_qt
  fi
  export SMART_PHOTOS_PROJECT_ROOT="$ROOT_DIR"
  export SMART_PHOTOS_VENV_PYTHON="$VENV_DIR/bin/python"
  exec "$TAURI_BINARY" "${passthrough[@]}"
fi

if [[ ! -x "$ELECTRON_BINARY" ]]; then
  echo "Electron UI is not installed. Falling back to the Qt diagnostics interface." >&2
  launch_qt
fi

export SMART_PHOTOS_VENV_PYTHON="$VENV_DIR/bin/python"
sanitize_electron_env
set +e
"$ELECTRON_BINARY" "$ELECTRON_DIR" "${passthrough[@]}"
electron_status=$?
set -e
if [[ "$electron_status" -ne 0 ]]; then
  echo "Electron UI exited unexpectedly. Falling back to the Qt diagnostics interface." >&2
  launch_qt
fi
exit 0
